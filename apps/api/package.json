{
  "name": "@neelkanth/api",
  "version": "0.0.0",
  "private": true,
  "description": "The runtime: composition root hosting the engines + control-plane HTTP API (plan/05)",
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "start": "node dist/main.js",
    "dev": "node --env-file=../../.env dist/main.js",
    "bootstrap:operator": "node --env-file=../../.env dist/bootstrap-operator.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@neelkanth/broker": "workspace:*",
    "@neelkanth/config": "workspace:*",
    "@neelkanth/contracts": "workspace:*",
    "@neelkanth/core": "workspace:*",
    "@neelkanth/db": "workspace:*",
    "@neelkanth/engines": "workspace:*",
    "@neelkanth/indicators": "workspace:*",
    "@neelkanth/logger": "workspace:*",
    "@neelkanth/redis": "workspace:*",
    "@neelkanth/strategies": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "mongodb": "^6.12.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "socket.io-client": "^4.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
